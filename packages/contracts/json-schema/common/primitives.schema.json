{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ggw://contracts/common/primitives",
  "title": "Common Primitives",
  "description": "公共原语类型。所有领域 Schema 通过 $ref 复用，不得各自重复定义。（母本 11.14 一致性、9.2、0.5）",
  "$defs": {
    "entity_id": {
      "type": "string",
      "description": "前缀式实体 ID：<prefix>_<ulid>，如 ws_01HXX…、cam_01HXX…。前缀映射：ws=Workspace org=Organization mem=Membership cmp=CompanyProfile off=Offering src=KnowledgeSource clm=Claim evd=Evidence icp=ICPDefinition acc=Account cta=Contact led=Lead cam=Campaign aud=Audience seq=OutreachSequence exp=Experiment auth=ExecutionAuthorization opp=Opportunity out=CommercialOutcome",
      "pattern": "^[a-z]{2,5}_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "workspace_id": {
      "type": "string",
      "description": "租户边界。所有业务对象必含（母本 ADR-001）。",
      "pattern": "^ws_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC（母本 11.14：所有时间保存 UTC）"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "乐观锁版本号（母本 11.16 optimistic locking）"
    },
    "money": {
      "type": "object",
      "description": "金额：保存币种与原始/换算值（母本 11.14）",
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "original_amount": { "type": "number" },
        "original_currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      },
      "required": ["amount", "currency"],
      "additionalProperties": false
    },
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2"
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "BCP 47 子集，如 zh-CN、en、vi、fr"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "置信度 0-1"
    },
    "privacy_classification": {
      "type": "string",
      "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL", "RESTRICTED"],
      "description": "数据分级（母本 12.11）"
    },
    "audit_base": {
      "type": "object",
      "description": "所有业务对象的公共字段（conventions.md）",
      "properties": {
        "id": { "$ref": "#/$defs/entity_id" },
        "workspace_id": { "$ref": "#/$defs/workspace_id" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "updated_at": { "$ref": "#/$defs/timestamp" },
        "version": { "$ref": "#/$defs/version" }
      },
      "required": ["id", "workspace_id", "created_at", "updated_at", "version"]
    }
  }
}
