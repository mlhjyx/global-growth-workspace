{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ggw://contracts/campaign/campaign-revision",
  "title": "CampaignRevision",
  "description": "Campaign 修订：运行中的重大变更创建 CampaignRevision 并展示差异；未经重新授权不能扩大受众、渠道、成本或风险；Revision 不覆盖历史配置和归因（CAM-006、母本 7.6.4）。ID 前缀 rev（对 primitives 前缀映射的补充）。负责域：campaign。schema_version=1。",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "rev_ 前缀实体 ID"
    },
    "workspace_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/workspace_id"
    },
    "campaign_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "cam_ 前缀，被修订的 Campaign"
    },
    "revision_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Campaign 内单调递增的修订序号（对应 Campaign.current_revision_number）"
    },
    "base_campaign_version": {
      "$ref": "ggw://contracts/common/primitives#/$defs/version",
      "description": "差异基准：本修订基于的 Campaign 乐观锁版本；VERSION_CONFLICT 时返回当前版本和 Diff，用户可合并或创建 Revision（母本 11.15）"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "变更原因说明"
    },
    "status": {
      "type": "string",
      "enum": ["PROPOSED", "APPROVED", "REJECTED", "APPLIED"],
      "description": "修订生命周期（对象级枚举）。requires_reauthorization=true 的修订必须先取得新 ExecutionAuthorization 才能 APPLIED（CAM-006）"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "description": "字段级差异列表，供审批页展示（CAM-006 差异展示）",
      "items": {
        "type": "object",
        "properties": {
          "field_path": {
            "type": "string",
            "minLength": 1,
            "description": "变更字段路径，如 budget.hard_cap、audience_ids、channel_plan_ids[0]"
          },
          "change_type": {
            "type": "string",
            "enum": ["ADDED", "REMOVED", "MODIFIED"],
            "description": "变更类型"
          },
          "old_value": true,
          "new_value": true
        },
        "required": ["field_path", "change_type"],
        "additionalProperties": false
      }
    },
    "risk_expansion": {
      "type": "object",
      "description": "风险扩大判定（CAM-006：未经重新授权不能扩大受众、渠道、成本或风险）",
      "properties": {
        "audience_expanded": { "type": "boolean", "description": "是否扩大受众范围" },
        "channel_expanded": { "type": "boolean", "description": "是否新增/扩大渠道" },
        "cost_increased": { "type": "boolean", "description": "是否提高成本/预算" },
        "risk_increased": { "type": "boolean", "description": "是否提升合规/账号健康等风险" }
      },
      "required": ["audience_expanded", "channel_expanded", "cost_increased", "risk_increased"],
      "additionalProperties": false
    },
    "requires_reauthorization": {
      "type": "boolean",
      "description": "是否需要重新授权；risk_expansion 任一为 true 时必须为 true（服务层强制，CAM-006、CAM-008）"
    },
    "superseding_authorization_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "auth_ 前缀，重新授权后签发的新 ExecutionAuthorization；旧授权置 SUPERSEDED（CAM-006、CAM-008）"
    },
    "created_by": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "mem_ 前缀，发起人"
    },
    "approved_by": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "mem_ 前缀，审批人（status=APPROVED/APPLIED 时填写）"
    },
    "approved_at": {
      "$ref": "ggw://contracts/common/primitives#/$defs/timestamp"
    },
    "applied_at": {
      "$ref": "ggw://contracts/common/primitives#/$defs/timestamp",
      "description": "修订生效时间；生效不覆盖历史配置与归因（7.6.4）"
    },
    "created_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "updated_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "version": { "$ref": "ggw://contracts/common/primitives#/$defs/version" }
  },
  "required": [
    "id",
    "workspace_id",
    "campaign_id",
    "revision_number",
    "base_campaign_version",
    "reason",
    "status",
    "changes",
    "risk_expansion",
    "requires_reauthorization",
    "created_by",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": false
}
