{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ggw://contracts/campaign/experiment",
  "title": "Experiment",
  "description": "实验：Variant、对照、假设与胜出规则；实验结果可回溯到资产（variants[].asset_ids）和受众（variants[].audience_id）（CAM-011；母本 5.7 Variant 和假设、7.6.2）。独立版本化（CAM-004）。ID 前缀 exp。负责域：campaign。schema_version=1。",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "exp_ 前缀实体 ID"
    },
    "workspace_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/workspace_id"
    },
    "campaign_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "cam_ 前缀，所属 Campaign（CAM-004、CAM-011）"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "实验名称"
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1,
      "description": "实验假设（CAM-011；母本 5.8.1 Campaign Hypothesis）"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "RUNNING", "EVALUATING", "CONCLUDED", "CANCELLED"],
      "description": "实验生命周期（对象级枚举，非母本 11.9 状态机）。CONCLUDED 时产出 ExperimentEvaluated 事件（母本 11.11 结果与学习）"
    },
    "variants": {
      "type": "array",
      "minItems": 2,
      "description": "变体列表，至少 2 个且必须恰好包含 1 个 is_control=true 的对照组（CAM-011；唯一性由服务层校验）",
      "items": {
        "type": "object",
        "properties": {
          "variant_key": {
            "type": "string",
            "minLength": 1,
            "description": "变体键，实验内唯一，如 control、variant_a"
          },
          "description": {
            "type": "string",
            "description": "变体说明（改动点）"
          },
          "is_control": {
            "type": "boolean",
            "description": "是否对照组（CAM-011）"
          },
          "asset_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "本变体使用的内容资产引用；保证结果可回溯到资产（CAM-011 验收）"
          },
          "audience_id": {
            "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
            "description": "aud_ 前缀，本变体投放的受众切片；保证结果可回溯到受众（CAM-011 验收）"
          },
          "traffic_allocation": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "流量分配比例（0-1）；全部变体之和应为 1（服务层校验）"
          }
        },
        "required": ["variant_key", "is_control"],
        "additionalProperties": false
      }
    },
    "control_variant_key": {
      "type": "string",
      "minLength": 1,
      "description": "对照组 variant_key，必须与 variants 中唯一 is_control=true 的条目一致（服务层校验，CAM-011）"
    },
    "winning_rule": {
      "type": "object",
      "description": "胜出规则（CAM-011）",
      "properties": {
        "primary_metric": {
          "type": "string",
          "minLength": 1,
          "description": "主指标，如 reply_rate、meeting_booked_rate、qualified_lead_count"
        },
        "comparison": {
          "type": "string",
          "enum": ["LIFT_OVER_CONTROL", "ABSOLUTE_TARGET"],
          "description": "判定方式：相对对照组提升 / 达到绝对目标值"
        },
        "min_lift": {
          "type": "number",
          "description": "comparison=LIFT_OVER_CONTROL 时的最小相对提升（如 0.1 表示 +10%）"
        },
        "target_value": {
          "type": "number",
          "description": "comparison=ABSOLUTE_TARGET 时的目标值"
        },
        "min_sample_size": {
          "type": "integer",
          "minimum": 1,
          "description": "每变体最小样本量，未达到不判定胜出"
        },
        "min_confidence": {
          "$ref": "ggw://contracts/common/primitives#/$defs/confidence",
          "description": "最小统计置信度（0-1）"
        },
        "evaluation_window_days": {
          "type": "integer",
          "minimum": 1,
          "description": "评估窗口（天）；窗口结束后进入 EVALUATING"
        }
      },
      "required": ["primary_metric", "comparison", "min_sample_size"],
      "additionalProperties": false
    },
    "winner_variant_key": {
      "type": "string",
      "description": "胜出变体（CONCLUDED 时填写；无显著差异时省略并在 result_summary 说明）"
    },
    "evaluated_at": {
      "$ref": "ggw://contracts/common/primitives#/$defs/timestamp",
      "description": "评估完成时间"
    },
    "result_summary": {
      "type": "string",
      "description": "结果摘要（供 LEARNED 阶段复盘与 Recommendation 引用，母本 5.13）"
    },
    "created_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "updated_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "version": {
      "$ref": "ggw://contracts/common/primitives#/$defs/version",
      "description": "乐观锁版本 = 独立版本化（CAM-004；母本 11.16）"
    }
  },
  "required": [
    "id",
    "workspace_id",
    "campaign_id",
    "name",
    "hypothesis",
    "status",
    "variants",
    "control_variant_key",
    "winning_rule",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": false
}
