{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ggw://contracts/knowledge/company-profile",
  "title": "CompanyProfile",
  "description": "企业画像：workspace 所属出海企业自身的已确认事实（母本 7.2.2 核心对象、6.5.1 首次价值路径步骤 1-3、KNW-002 自动提取候选）。注意与 data-hub 域 CanonicalCompany（外部目标客户公司，附录 C）区分：本对象是『卖方自己是谁』。确认动作触发 CompanyProfileConfirmed 事件（母本 11.11）。负责域：knowledge；schema_version=1。",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cmp_[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "前缀式实体 ID，前缀 cmp（common/primitives entity_id 前缀映射）"
    },
    "workspace_id": { "$ref": "ggw://contracts/common/primitives#/$defs/workspace_id" },
    "legal_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "法定名称（KNW-002 企业事实候选）"
    },
    "display_name": {
      "type": "string",
      "maxLength": 200,
      "description": "对外展示名称"
    },
    "trading_names": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "description": "商号/曾用名/英文名等别名"
    },
    "websites": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "官网与相关域名，是 WEBSITE 类 KnowledgeSource 的起点（KNW-001）"
    },
    "hq_country": {
      "$ref": "ggw://contracts/common/primitives#/$defs/country_code",
      "description": "总部所在国家"
    },
    "locations": {
      "type": "array",
      "description": "工厂/办公/仓库等地点（母本 4.8.1 企业事实：品牌、工厂、团队、区域、能力）",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 200 },
          "location_type": {
            "type": "string",
            "enum": ["HQ", "FACTORY", "OFFICE", "WAREHOUSE", "SHOWROOM"],
            "description": "地点类型"
          },
          "country": { "$ref": "ggw://contracts/common/primitives#/$defs/country_code" },
          "city": { "type": "string", "maxLength": 100 }
        },
        "required": ["location_type", "country"],
        "additionalProperties": false
      }
    },
    "founded_year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100,
      "description": "成立年份"
    },
    "employee_range": {
      "type": "string",
      "enum": ["1-10", "11-50", "51-200", "201-500", "501-1000", "1001-5000", "5000+"],
      "description": "员工规模区间（对齐附录 C CanonicalCompany employee_range 口径）"
    },
    "industries": {
      "type": "array",
      "items": { "type": "string", "maxLength": 100 },
      "description": "所属行业标签"
    },
    "description": {
      "type": "string",
      "maxLength": 5000,
      "description": "企业简介（提取候选经确认后写入，母本 7.2.5：推断必须经过审核）"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "maxLength": 300 },
      "description": "能力概要（KNW-002 能力候选；权威能力事实以 CAPABILITY 类型 Claim 为准）"
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 },
      "description": "认证概要（展示用；权威认证事实以 CERTIFICATION 类型 Claim + Evidence 为准，母本 7.2.4）"
    },
    "main_markets": {
      "type": "array",
      "items": { "$ref": "ggw://contracts/common/primitives#/$defs/country_code" },
      "description": "当前主要出口/目标市场"
    },
    "languages": {
      "type": "array",
      "items": { "$ref": "ggw://contracts/common/primitives#/$defs/locale" },
      "description": "企业可用沟通语言"
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^src_[0-9A-HJKMNP-TV-Z]{26}$" },
      "description": "支撑本画像的 KnowledgeSource 列表（KNW-001）"
    },
    "confirmation_status": {
      "type": "string",
      "enum": ["DRAFT", "PENDING_CONFIRMATION", "CONFIRMED"],
      "description": "画像确认状态：用户确认企业画像后进入 CONFIRMED 并发布 CompanyProfileConfirmed 事件（母本 6.5.1 步骤 3、11.11）"
    },
    "confirmed_by": {
      "type": "string",
      "pattern": "^mem_[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "确认人 Membership ID"
    },
    "confirmed_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "created_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "updated_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "version": { "$ref": "ggw://contracts/common/primitives#/$defs/version" }
  },
  "required": [
    "id",
    "workspace_id",
    "legal_name",
    "confirmation_status",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": false
}
