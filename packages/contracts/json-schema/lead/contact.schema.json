{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ggw://contracts/lead/contact",
  "title": "Contact",
  "description": "企业中的个人职业联系人（母本 7.5.2、附录 C CanonicalContact 最小字段：names/current_role/buying_role/contact_points/verification/employment_history/consent+suppression/last_verified_at；LED-013：邮箱/电话/社交资料验证与显示权限，未授权角色只能看到脱敏字段；母本 8.9：按需揭示、加密、TTL、抑制）。字段级来源证据在 common/field-evidence。负责域：lead；schema_version=1。id 前缀 cta_。",
  "type": "object",
  "$defs": {
    "contact_point": {
      "type": "object",
      "description": "联系方式（母本 8.8 ContactPoint：邮箱、电话、社交账号及验证/同意/抑制状态）。value 存储加密（母本 8.9）；API 明文返回受 Policy 动作 VIEW（contact.contact_point.view）控制，未授权时仅返回 value_masked（LED-013 验收）；导出受 EXPORT、外联受 OUTREACH 控制（母本 8.10）",
      "properties": {
        "contact_point_id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "EMAIL",
            "PHONE",
            "LINKEDIN",
            "WHATSAPP",
            "WECHAT",
            "FACEBOOK",
            "X",
            "OTHER_SOCIAL"
          ],
          "description": "联系方式类型（LED-013：邮箱、电话、社交资料）"
        },
        "value": {
          "type": "string",
          "description": "明文值；仅当 Policy VIEW 判定 Allow 时出现在响应中（LED-013）"
        },
        "value_masked": { "type": "string", "description": "脱敏展示值，如 j***@acme.com" },
        "value_hash": {
          "type": "string",
          "description": "不可逆哈希，用于 Suppression 匹配与去重（母本 11.17：Suppression 保留最小不可逆标识）"
        },
        "is_primary": { "type": "boolean" },
        "verification_status": {
          "type": "string",
          "enum": ["UNVERIFIED", "PENDING", "VALID", "INVALID", "RISKY", "EXPIRED"],
          "description": "验证状态（LED-013；母本 4.5.5：邮箱未验证不能批量发送；8.9：发送前实时验证）"
        },
        "verified_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
        "verification_provider_id": { "type": "string", "description": "执行验证的 Provider" },
        "consent_status": {
          "type": "string",
          "enum": ["UNKNOWN", "OPT_IN", "OPT_OUT", "WITHDRAWN"],
          "description": "该联系方式的同意状态（附录 C consent）"
        },
        "suppressed": {
          "type": "boolean",
          "description": "是否被 SuppressionRecord 命中（母本 8.9 全局抑制）"
        },
        "expires_at": {
          "$ref": "ggw://contracts/common/primitives#/$defs/timestamp",
          "description": "TTL：超期自动隐藏/删除（母本 8.9）"
        }
      },
      "required": ["contact_point_id", "type", "verification_status"],
      "additionalProperties": false
    },
    "employment_record": {
      "type": "object",
      "description": "任职历史（附录 C employment_history；母本 7.4.10：联系人换公司后保留 Employment History，不覆盖历史关系；8.9：职位和任职关系带有效期）",
      "properties": {
        "account_id": { "$ref": "ggw://contracts/common/primitives#/$defs/entity_id" },
        "company_name": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "started_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
        "ended_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
        "is_current": { "type": "boolean" },
        "source_evidence_id": { "type": "string", "description": "FieldEvidence 引用" }
      },
      "required": ["company_name", "is_current"],
      "additionalProperties": false
    },
    "consent_record": {
      "type": "object",
      "description": "同意/许可记录（附录 C consent；母本 DAT-014 用途与反对状态管理）",
      "properties": {
        "purpose": { "type": "string", "description": "处理目的，如 outreach、lead_research" },
        "channel": {
          "type": "string",
          "enum": ["EMAIL", "PHONE", "SOCIAL", "ALL"],
          "description": "适用渠道"
        },
        "status": { "type": "string", "enum": ["OPT_IN", "OPT_OUT", "WITHDRAWN", "UNKNOWN"] },
        "legal_basis": {
          "type": "string",
          "description": "法律依据，如 legitimate_interest、consent"
        },
        "captured_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
        "source": {
          "type": "string",
          "description": "来源，如 web_form、import、unsubscribe_link"
        },
        "expires_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" }
      },
      "required": ["purpose", "status", "captured_at"],
      "additionalProperties": false
    },
    "merge_operation": {
      "type": "object",
      "description": "合并/拆分历史条目（LED-010；与 account.schema.json merge_operation 同构；母本 11.16 可回放命令与审计）",
      "properties": {
        "operation_id": { "type": "string" },
        "operation": { "type": "string", "enum": ["MERGE", "SPLIT", "UNDO_MERGE", "UNDO_SPLIT"] },
        "source_entity_ids": {
          "type": "array",
          "items": { "$ref": "ggw://contracts/common/primitives#/$defs/entity_id" }
        },
        "result_entity_ids": {
          "type": "array",
          "items": { "$ref": "ggw://contracts/common/primitives#/$defs/entity_id" }
        },
        "operated_by": { "type": "string" },
        "operated_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
        "confidence": { "$ref": "ggw://contracts/common/primitives#/$defs/confidence" },
        "reason": { "type": "string" },
        "undo_of_operation_id": { "type": "string" },
        "audit_log_id": { "type": "string" }
      },
      "required": [
        "operation_id",
        "operation",
        "source_entity_ids",
        "result_entity_ids",
        "operated_by",
        "operated_at"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "前缀 cta_（primitives 前缀映射）"
    },
    "workspace_id": { "$ref": "ggw://contracts/common/primitives#/$defs/workspace_id" },
    "account_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "当前所属 Account（acc_ 前缀，附录 C company_id）"
    },
    "canonical_person_id": {
      "$ref": "ggw://contracts/common/primitives#/$defs/entity_id",
      "description": "指向 Data Hub CanonicalPerson（母本 8.8）"
    },
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "附录 C names"
    },
    "given_name": { "type": "string" },
    "family_name": { "type": "string" },
    "alternate_names": { "type": "array", "items": { "type": "string" } },
    "current_role": {
      "type": "object",
      "description": "当前职位（附录 C current_role；带有效期，母本 8.9）",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "seniority": {
          "type": "string",
          "enum": ["C_LEVEL", "VP", "DIRECTOR", "MANAGER", "INDIVIDUAL_CONTRIBUTOR", "OWNER"]
        },
        "started_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" }
      },
      "additionalProperties": false
    },
    "buying_role": {
      "type": "string",
      "enum": ["DECISION_MAKER", "INFLUENCER", "USER", "TECHNICAL", "FINANCE", "PROCUREMENT"],
      "description": "购买委员会角色（附录 C buying_role；LED-002；取值与 buying-committee-role.schema.json 一致）"
    },
    "contact_points": {
      "type": "array",
      "items": { "$ref": "#/$defs/contact_point" },
      "description": "联系方式集合（附录 C contact_points；LED-013 验证与显示权限）"
    },
    "employment_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/employment_record" },
      "description": "任职历史（附录 C employment_history）"
    },
    "consent_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/consent_record" },
      "description": "同意记录（附录 C consent）"
    },
    "suppression": {
      "type": "object",
      "description": "抑制状态快照（附录 C suppression；权威记录在 suppression-record.schema.json；母本 4.5.5 全局抑制优先）",
      "properties": {
        "suppressed": { "type": "boolean" },
        "suppression_record_ids": {
          "type": "array",
          "items": { "$ref": "ggw://contracts/common/primitives#/$defs/entity_id" },
          "description": "sup_ 前缀"
        }
      },
      "required": ["suppressed"],
      "additionalProperties": false
    },
    "country": { "$ref": "ggw://contracts/common/primitives#/$defs/country_code" },
    "locale": { "$ref": "ggw://contracts/common/primitives#/$defs/locale" },
    "last_verified_at": {
      "$ref": "ggw://contracts/common/primitives#/$defs/timestamp",
      "description": "附录 C last_verified_at"
    },
    "merge_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/merge_operation" },
      "description": "合并/拆分历史（LED-010）"
    },
    "created_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "updated_at": { "$ref": "ggw://contracts/common/primitives#/$defs/timestamp" },
    "version": { "$ref": "ggw://contracts/common/primitives#/$defs/version" }
  },
  "required": [
    "id",
    "workspace_id",
    "account_id",
    "full_name",
    "contact_points",
    "created_at",
    "updated_at",
    "version"
  ],
  "additionalProperties": false
}
