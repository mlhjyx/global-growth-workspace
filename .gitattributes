# Normalize line endings to LF in the repo; check out native on Windows.
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never diff/merge as text
*.docx binary
*.xlsx binary
*.pptx binary
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.woff binary
*.woff2 binary
*.mp4  binary
