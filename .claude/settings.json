{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm -w run lint)",
      "Bash(pnpm -w run typecheck)",
      "Bash(pnpm -w run test)",
      "Bash(pnpm -w run format:check)",
      "Bash(pnpm -w run contracts:validate)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git show:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)"
    ],
    "deny": ["Bash(git push --force:*)", "Bash(git push -f:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-protected-paths.mjs"
          }
        ]
      }
    ]
  }
}
